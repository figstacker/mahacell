```
# Dependencies
node_modules/

# Build outputs
dist/
build/
target/

# Environment variables
.env
.env.local
*.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp

# Python cache (if any Python files exist in project)
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage reports
coverage/
htmlcov/
.coverage

# Package lock files (already tracking package-lock.json)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db

# Vite build cache
.node_build/

# TypeScript cache
*.tsbuildinfo
```